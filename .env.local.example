# ─── Database (Supabase) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Auth (NextAuth.js) ───────────────────────────────────────────────────────
AUTH_SECRET=your-secret-here # same as NEXTAUTH_SECRET
BASIC_AUTH_PASSWORD=
BASIC_AUTH_USER=
NEXTAUTH_SECRET=your-secret-here # same as AUTH_SECRET
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers - aktuell augebaut
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── AI ───────────────────────────────────────────────────────────────────────
# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Voyage AI (Embeddings) — https://dash.voyageai.com/
VOYAGE_API_KEY=

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
